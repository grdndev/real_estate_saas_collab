# ============================================================
# Équatis — Variables d'environnement (modèle)
# Copier ce fichier en .env et remplir les valeurs.
# Ne JAMAIS committer le .env.
# ============================================================

# --- Application ---
# Production : https://equatis.fr (à remplacer)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# --- Base de données (Postgres) ---
# Local Docker Compose :
DATABASE_URL="postgresql://equatis:equatis_dev_password@localhost:5432/equatis?schema=public"
# Production OVH :
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"

# --- Auth.js / JWT ---
# Générer : openssl rand -base64 32
AUTH_SECRET="REPLACE_ME_WITH_random_base64_32_bytes"
AUTH_TRUST_HOST="true"
# Durées :
ACCESS_TOKEN_TTL_SECONDS="3600"      # 1 heure (CDC §3.3)
REFRESH_TOKEN_TTL_SECONDS="604800"   # 7 jours (CDC §3.3)
SESSION_INACTIVITY_MINUTES="30"      # déconnexion auto (CDC §3.3)
LOGIN_LOCK_MINUTES="15"              # blocage après 5 échecs (CDC §3.2)
LOGIN_MAX_ATTEMPTS="5"

# --- Chiffrement champs perso (AES-256-GCM) ---
# Générer : openssl rand -hex 32   (32 bytes = 64 hex chars)
DATA_ENCRYPTION_KEY="REPLACE_ME_64_hex_chars"

# --- Stockage fichiers (S3-compatible) ---
# DEV (MinIO local via docker-compose) :
#   S3_ENDPOINT="http://localhost:9000"
#   S3_REGION="us-east-1"
#   S3_BUCKET="equatis-documents-dev"
#   S3_ACCESS_KEY_ID="minio"
#   S3_SECRET_ACCESS_KEY="minio_dev_password"
# PROD (OVH Object Storage) :
S3_ENDPOINT="https://s3.gra.io.cloud.ovh.net"
S3_REGION="gra"
S3_BUCKET="equatis-documents"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# --- ClamAV (scan antivirus) ---
# Laisser vide en dev/CI pour utiliser le scanner stub (auto-CLEAN sauf marqueur EICAR/VIRUS_TEST).
# En prod : pointer vers un daemon clamd accessible en TCP.
CLAMAV_HOST=""
CLAMAV_PORT=""

# --- Yousign (Phase 4 — signature électronique simple) ---
YOUSIGN_API_KEY=""
YOUSIGN_API_URL="https://api-sandbox.yousign.app/v3"
YOUSIGN_WEBHOOK_SECRET=""

# --- Email transactionnel (Brevo, Phase 4) ---
BREVO_API_KEY=""
EMAIL_FROM="no-reply@equatis.fr"
EMAIL_FROM_NAME="Équatis"

# --- Monitoring (Phase 5) ---
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
