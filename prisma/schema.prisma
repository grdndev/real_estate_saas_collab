// Équatis — schéma Prisma single-tenant
// Généré pour Phase 1. Toute modification doit passer par une migration versionnée.
// Conformité CDC v1.0 — 4 espaces cloisonnés (Collaborateur, Promoteur, Notaire, Client).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =====================================================
// ENUMS
// =====================================================

enum UserRole {
  SUPER_ADMIN
  COLLABORATOR
  PROMOTER
  NOTARY
  CLIENT
}

enum UserStatus {
  PENDING_EMAIL // inscription faite, email pas encore confirmé
  PENDING_ASSOCIATION // client confirmé mais pas associé à un dossier
  ACTIVE
  SUSPENDED
  DELETION_REQUESTED // demande RGPD en cours, soft-deleted
}

enum ProgrammeStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum LotStatus {
  AVAILABLE
  RESERVED
  SOLD
  WITHDRAWN
}

enum DossierStatus {
  NEW_LEAD
  RESERVATION_SENT
  SIGNATURE_PENDING
  SIGNED_AT_NOTARY
  LOAN_OFFER_RECEIVED
  ACT_SIGNED
  BLOCKED
}

enum DossierRole {
  COLLABORATOR_PRIMARY
  COLLABORATOR_SECONDARY
  NOTARY
}

enum DocumentScanStatus {
  PENDING
  CLEAN
  INFECTED
  ERROR
}

enum DocumentSource {
  COLLABORATOR_UPLOAD
  CLIENT_UPLOAD
  YOUSIGN_SIGNED
  PROGRAMME_RESOURCE
}

enum TimelineKind {
  LEAD_CREATED
  COMMERCIAL_MEETING
  RESERVATION_SENT
  RESERVATION_SIGNED
  TRANSMITTED_TO_NOTARY
  GUARANTEE_DEPOSIT_RECEIVED
  LOAN_OFFER_RECEIVED
  ACT_SIGNED
  STATUS_CHANGE
  DOCUMENT_REQUESTED
  CUSTOM
}

enum SignatureStatus {
  CREATED
  SENT
  OPENED
  SIGNED
  REFUSED
  EXPIRED
  ERROR
}

enum NotificationKind {
  NEW_DOCUMENT
  DOCUMENT_REQUESTED
  SIGNATURE_COMPLETED
  DOSSIER_INACTIVE
  NEW_LEAD
  TRANSMITTED_TO_NOTARY
  MISSING_PIECE_REPORTED
  NEW_MESSAGE
  DOSSIER_ASSOCIATED
  ACT_READY
}

// =====================================================
// AUTH & USERS
// =====================================================

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  emailVerifiedAt DateTime?
  passwordHash    String
  role            UserRole
  status          UserStatus @default(PENDING_EMAIL)

  firstName  String
  lastName   String
  // Champs sensibles : chiffrés AES-256-GCM côté application (clé via env).
  // Stockés sous forme `iv:tag:ciphertext` en base64.
  phoneEnc   String?
  addressEnc String?

  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?
  lastLoginAt      DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  sessions           Session[]
  passwordResets     PasswordReset[]
  emailVerifications EmailVerification[]
  dossierLinks       DossierParticipant[]
  clientDossier      Dossier?             @relation("DossierClient")
  promoterProgrammes ProgrammePromoter[]
  uploadedDocs       Document[]
  notifications      Notification[]
  auditLogs          AuditLog[]
  sentMessages       Message[]
  signaturesAsSigner Signature[]          @relation("SignatureSigner")

  @@index([role])
  @@index([status])
}

// Refresh tokens persistés. L'access token JWT est volatile (1h) et n'est pas stocké.
model Session {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String    @unique
  userAgent        String?
  ip               String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerification {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Trace de chaque tentative — base du rate limiting (5 échecs → 15 min).
model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String
  userAgent String?
  success   Boolean
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ip, createdAt])
}

// =====================================================
// PROGRAMMES & LOTS
// =====================================================

model Programme {
  id          String          @id @default(cuid())
  reference   String          @unique
  name        String
  description String?
  city        String?
  status      ProgrammeStatus @default(ACTIVE)
  totalLots   Int             @default(0)
  caObjective Decimal?        @db.Decimal(14, 2)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  lots       Lot[]
  dossiers   Dossier[]
  documents  ProgrammeDocument[]
  promoters  ProgrammePromoter[]
  tresorerie TresoreriePrev[]

  @@index([status])
}

// Plusieurs promoteurs possibles par programme.
model ProgrammePromoter {
  programmeId String
  promoterId  String
  createdAt   DateTime @default(now())

  programme Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  promoter  User      @relation(fields: [promoterId], references: [id], onDelete: Cascade)

  @@id([programmeId, promoterId])
  @@index([promoterId])
}

model Lot {
  id          String    @id @default(cuid())
  programmeId String
  reference   String
  surface     Decimal   @db.Decimal(8, 2)
  floor       Int?
  type        String
  priceHT     Decimal   @db.Decimal(12, 2)
  vatRate     Decimal   @db.Decimal(5, 2)
  priceTTC    Decimal   @db.Decimal(12, 2)
  status      LotStatus @default(AVAILABLE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  programme Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  dossiers  Dossier[]

  @@unique([programmeId, reference])
  @@index([programmeId, status])
}

// Trésorerie prévisionnelle : 1 ligne par mois.
model TresoreriePrev {
  id          String   @id @default(cuid())
  programmeId String
  month       DateTime
  income      Decimal  @default(0) @db.Decimal(14, 2)
  expense     Decimal  @default(0) @db.Decimal(14, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  programme Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)

  @@unique([programmeId, month])
}

// =====================================================
// DOSSIERS
// =====================================================

model Dossier {
  id          String        @id @default(cuid())
  reference   String        @unique
  programmeId String
  lotId       String?
  clientId    String?       @unique
  status      DossierStatus @default(NEW_LEAD)

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  // Mis à jour automatiquement par triggers applicatifs : base des relances auto.
  lastActivityAt      DateTime  @default(now())
  closedAt            DateTime?
  notaryId            String?
  notaryTransmittedAt DateTime?

  programme        Programme            @relation(fields: [programmeId], references: [id])
  lot              Lot?                 @relation(fields: [lotId], references: [id])
  client           User?                @relation("DossierClient", fields: [clientId], references: [id])
  participants     DossierParticipant[]
  documents        Document[]
  documentRequests DocumentRequest[]
  timelineEvents   TimelineEvent[]
  messages         Message[]
  signatures       Signature[]

  @@index([status])
  @@index([programmeId])
  @@index([lastActivityAt])
  @@index([notaryId, status])
}

// Lien M2M : un user peut être collaborateur principal/secondaire ou notaire d'un dossier.
model DossierParticipant {
  dossierId String
  userId    String
  role      DossierRole
  createdAt DateTime    @default(now())

  dossier Dossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([dossierId, userId, role])
  @@index([userId, role])
}

// =====================================================
// DOCUMENTS
// =====================================================

model Document {
  id                String             @id @default(cuid())
  dossierId         String?
  uploadedById      String
  fileName          String
  mimeType          String
  sizeBytes         Int
  storageKey        String             @unique
  source            DocumentSource
  scanStatus        DocumentScanStatus @default(PENDING)
  scanCheckedAt     DateTime?
  documentRequestId String?

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  dossier    Dossier?         @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  uploadedBy User             @relation(fields: [uploadedById], references: [id])
  request    DocumentRequest? @relation(fields: [documentRequestId], references: [id])

  @@index([dossierId, createdAt])
  @@index([scanStatus])
  @@index([uploadedById])
}

// Documents attachés à un programme (plans, permis, notice, budget, acte type).
model ProgrammeDocument {
  id          String @id @default(cuid())
  programmeId String
  fileName    String
  storageKey  String @unique
  mimeType    String
  sizeBytes   Int
  category    String

  createdAt DateTime @default(now())

  programme Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)

  @@index([programmeId, category])
}

// Pièces demandées au client par le collaborateur (ex : pièce d'identité recto, RIB, etc.).
model DocumentRequest {
  id        String  @id @default(cuid())
  dossierId String
  label     String
  required  Boolean @default(true)
  fulfilled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dossier   Dossier    @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  documents Document[]

  @@index([dossierId, fulfilled])
}

// =====================================================
// TIMELINE
// =====================================================

model TimelineEvent {
  id          String       @id @default(cuid())
  dossierId   String
  kind        TimelineKind
  title       String
  description String?
  occurredAt  DateTime     @default(now())
  actorId     String?

  createdAt DateTime @default(now())

  dossier Dossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)

  @@index([dossierId, occurredAt])
}

// =====================================================
// MESSAGERIE CLIENT ↔ COLLABORATEUR
// =====================================================

model Message {
  id        String    @id @default(cuid())
  dossierId String
  senderId  String
  body      String
  readAt    DateTime?

  createdAt DateTime @default(now())

  dossier Dossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  sender  User    @relation(fields: [senderId], references: [id])

  @@index([dossierId, createdAt])
}

// =====================================================
// SIGNATURE ÉLECTRONIQUE (Yousign SES)
// =====================================================

model Signature {
  id                 String          @id @default(cuid())
  dossierId          String
  documentId         String?
  yousignProcedureId String?         @unique
  status             SignatureStatus @default(CREATED)
  signerEmail        String
  signerUserId       String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  signedAt  DateTime?

  dossier    Dossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  signerUser User?   @relation("SignatureSigner", fields: [signerUserId], references: [id])

  @@index([dossierId, status])
  @@index([yousignProcedureId])
}

// =====================================================
// NOTIFICATIONS IN-APP
// =====================================================

model Notification {
  id     String           @id @default(cuid())
  userId String
  kind   NotificationKind
  title  String
  body   String?
  link   String?
  readAt DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

// =====================================================
// AUDIT LOGS — conservation 5 ans (CDC §8.6)
// =====================================================

model AuditLog {
  id           String  @id @default(cuid())
  userId       String?
  action       String
  resourceType String
  resourceId   String?
  metadata     Json?
  ip           String?
  userAgent    String?

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([resourceType, resourceId, createdAt])
  @@index([action, createdAt])
}

// =====================================================
// PARAMÈTRES GLOBAUX (CDC §9.3)
// =====================================================

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?
}
